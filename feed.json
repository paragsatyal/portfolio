        {
            "id": "https://paragsatyal.github.io/portfolio/fox-netball-ident-2/",
            "url": "https://paragsatyal.github.io/portfolio/fox-netball-ident-2/",
            "title": "Fox Netball Ident",
            "summary": "Fox Netball ident for Fox Sports Australia. My job on this was to mainly work on surfacing and lighting. The&hellip;",
            "content_html": "<figure class=\"post__video\"><iframe loading=\"lazy\" width=\"425\" height=\"239\" src=\"https://player.vimeo.com/video/910358909?title=0&amp;byline=0&amp;portrait=0&amp;color=8dc7dc&dnt=1\" allowfullscreen=\"allowfullscreen\" data-mce-fragment=\"1\"></iframe></figure>\n<div id=\"yui_3_17_2_1_1782027831577_109\" class=\"image-list\">\n<div id=\"yui_3_17_2_1_1782027831577_108\" class=\"image\">\n<div id=\"yui_3_17_2_1_1782027831577_116\" class=\"sqs-video-wrapper video-none\" data-load=\"false\" data-html=\"&lt;iframe allow=&quot;autoplay; fullscreen; picture-in-picture&quot; allowfullscreen src=&quot;https://player.vimeo.com/video/711921077?h=ce92825141&amp;amp;app_id=122963&amp;amp;wmode=opaque&quot; width=&quot;426&quot; frameborder=&quot;0&quot; title=&quot;Foxtel_F1_15secIdent_4K.mp4&quot; height=&quot;240&quot;&gt;&lt;/iframe&gt;\" data-provider-name=\"Vimeo\">\n<div class=\"intrinsic\">\n<div class=\"intrinsic-inner\">\n<div id=\"yui_3_17_2_1_1782027831577_1063\" class=\"sqs-video-overlay\">\n<div class=\"sqs-video-icon\" tabindex=\"0\" role=\"button\" aria-label=\"Play\">\n<div class=\"project-meta\">\n<div class=\"project-description\">\n<p class=\"\">Fox Netball ident for Fox Sports Australia. My job on this was to mainly work on surfacing and lighting. The netball was was textured in Substance painter as it needed to be rendered in 4K, and mostly featured closeups.<br><br>3D Artists: Parag Satyal, Grischa Theissen, Patrick Lloyd<br><br>Awards:</p>\n<ul>\n<li>Promax ANZ 2023 Best Ident Design - Silver</li>\n</ul>\n<div class=\"gallery-wrapper\"><div class=\"gallery\" data-is-empty=\"false\" data-translation=\"Add images\" data-columns=\"4\">\n<figure class=\"gallery__item\"><a href=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/thumb.jpg\" data-size=\"1920x1080\"><img loading=\"lazy\" src=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/thumb-thumbnail.jpg\" alt=\"\" width=\"768\" height=\"432\"></a></figure>\n<figure class=\"gallery__item\"><a href=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.11.png\" data-size=\"1920x1080\"><img loading=\"lazy\" src=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.11-thumbnail.png\" alt=\"\" width=\"768\" height=\"432\"></a></figure>\n<figure class=\"gallery__item\"><a href=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.19.png\" data-size=\"1920x1080\"><img loading=\"lazy\" src=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.19-thumbnail.png\" alt=\"\" width=\"768\" height=\"432\"></a></figure>\n<figure class=\"gallery__item\"><a href=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.23.png\" data-size=\"1920x1080\"><img loading=\"lazy\" src=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.23-thumbnail.png\" alt=\"\" width=\"768\" height=\"432\"></a></figure>\n<figure class=\"gallery__item\"><a href=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.28.png\" data-size=\"1920x1080\"><img loading=\"lazy\" src=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.28-thumbnail.png\" alt=\"\" width=\"768\" height=\"432\"></a></figure>\n<figure class=\"gallery__item\"><a href=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.39.png\" data-size=\"1920x1080\"><img loading=\"lazy\" src=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.39-thumbnail.png\" alt=\"\" width=\"768\" height=\"432\"></a></figure>\n<figure class=\"gallery__item\"><a href=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.53.png\" data-size=\"1920x1080\"><img loading=\"lazy\" src=\"https://paragsatyal.github.io/portfolio/media/posts/40/gallery/Untitled-Project_NETBALL_IDENT_HD_25FPS_Netball4_2024-02-06_21.18.53-thumbnail.png\" alt=\"\" width=\"768\" height=\"432\"></a></figure>\n</div></div>\n</div>\n</div>\n<div id=\"yui_3_17_2_1_1782028277602_79\" class=\"image-list\">\n<div id=\"yui_3_17_2_1_1782028277602_78\" class=\"image\">\n<div id=\"yui_3_17_2_1_1782028277602_87\" class=\"sqs-video-wrapper video-none\" data-load=\"false\" data-html=\"&lt;iframe allow=&quot;autoplay; fullscreen; picture-in-picture&quot; src=&quot;https://player.vimeo.com/video/910358909?h=6773ef3ec8&amp;amp;app_id=122963&amp;amp;wmode=opaque&quot; width=&quot;426&quot; frameborder=&quot;0&quot; title=&quot;Fox Netball Ident 2023&quot; height=&quot;240&quot;&gt;&lt;/iframe&gt;\" data-provider-name=\"Vimeo\">\n<div class=\"intrinsic\">\n<div class=\"intrinsic-inner\">\n<div id=\"yui_3_17_2_1_1782028277602_1070\" class=\"sqs-video-overlay\"><br>\n<div class=\"sqs-video-opaque\"> </div>\n<div class=\"sqs-video-icon\" tabindex=\"0\" role=\"button\" aria-label=\"Play\"> </div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>",
